#!/bin/bash
#
# Pre-push hook: bloqueia o push se a cobertura de instruções na camada
# application/usecase estiver abaixo de 80% (verificado via JaCoCo).
#
# Para ignorar esta verificação use: git push --no-verify
#

echo ""
echo "=========================================="
echo "  Pre-push: verificando cobertura (JaCoCo)"
echo "=========================================="
echo ""

ROOT=$(git rev-parse --show-toplevel)
cd "$ROOT" || exit 1

if ! command -v mvn &>/dev/null; then
    echo "AVISO: 'mvn' não encontrado no PATH. Verificação ignorada."
    exit 0
fi

mvn verify --no-transfer-progress

EXIT_CODE=$?

if [ "$EXIT_CODE" -ne 0 ]; then
    echo ""
    echo "=========================================="
    echo "  PUSH BLOQUEADO"
    echo ""
    echo "  Cobertura de testes < 80% na camada:"
    echo "  application/usecase"
    echo ""
    echo "  Relatório: target/site/jacoco/index.html"
    echo "  Para ignorar: git push --no-verify"
    echo "=========================================="
    echo ""
    exit 1
fi

echo ""
echo "  Cobertura OK — push autorizado."
echo "=========================================="
echo ""
exit 0
